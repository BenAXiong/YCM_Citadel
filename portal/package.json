{
  "name": "portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -e \"const fs=require('fs'); if(fs.existsSync('../export/ycm_master.db')) fs.copyFileSync('../export/ycm_master.db', './ycm_master.db')\" && next dev",
    "build": "curl -L -o ./ycm_master.db https://github.com/BenAXiong/YCM_Citadel/raw/main/export/ycm_master.db && curl -L -o ./amis_moe_test.db https://github.com/BenAXiong/YCM_Citadel/raw/main/data/amis_moe_test.db && next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
